{
    "name": "Saved Items",
    "short_name": "Saved",
    "description": "Save links, videos and images.",
    "start_url": "/saved-items",
    "scope": "/",
    "display": "standalone",
    "background_color": "#0B0B0D",
    "theme_color": "#DC143C",
    "orientation": "portrait",
